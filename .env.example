# Runtime environment: development, test, or production.
APP_ENV=development

# Async SQLAlchemy PostgreSQL URL. Required. Use the postgresql+asyncpg scheme.
# Supply credentials through a local untracked .env file or a platform secret store.
DATABASE_URL=

# Structured logging. LOG_JSON should be true in production.
LOG_LEVEL=INFO
LOG_JSON=false

# Interactive API documentation is useful locally and must be false in production.
DOCS_ENABLED=true

# Database pool and readiness settings.
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=10
DATABASE_READY_TIMEOUT_SECONDS=2

# JSON arrays. Production origins must use HTTPS and hosts must be explicit.
CORS_ORIGINS=[]
TRUSTED_HOSTS=["localhost","127.0.0.1"]

# Local PostgreSQL container settings. POSTGRES_PASSWORD is a secret and must be set.
POSTGRES_DB=repolume
POSTGRES_USER=repolume
POSTGRES_PASSWORD=
