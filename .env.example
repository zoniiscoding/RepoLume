# Runtime environment: development, test, or production.
APP_ENV=development

# Async SQLAlchemy PostgreSQL URL. Required. Use the postgresql+asyncpg scheme.
# Supply credentials through a local untracked .env file or a platform secret store.
DATABASE_URL=

# Disposable PostgreSQL URL used only by the integration suite. Never point this
# at a development, staging, or production database because tests truncate it.
TEST_DATABASE_URL=

# Structured logging. LOG_JSON should be true in production.
LOG_LEVEL=INFO
LOG_JSON=false

# Interactive API documentation is useful locally and must be false in production.
DOCS_ENABLED=true

# Database pool and readiness settings.
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=10
DATABASE_READY_TIMEOUT_SECONDS=2

# GitHub App identity and OAuth. Configure the app with read-only Contents,
# Metadata, and Pull requests permissions and subscribe to installation,
# installation_repositories, push, and repository events. IDs are identifiers;
# client secret, private key, and webhook secret are secrets.
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://127.0.0.1:8000/api/v1/auth/github/callback

# RepoLume token signing and keyed hashing secrets. Use independent random values
# of at least 32 characters, supplied by a secret store in production.
ACCESS_TOKEN_SECRET=
TOKEN_HASH_SECRET=

# Authentication lifetimes in seconds. Defaults are 10-minute OAuth state,
# 15-minute access token, 30-day refresh token, and 8-hour membership freshness.
OAUTH_STATE_TTL_SECONDS=600
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
INSTALLATION_MEMBERSHIP_TTL_SECONDS=28800
REFRESH_COOKIE_NAME=repolume_refresh_token

# JSON arrays. Production origins must use HTTPS and hosts must be explicit.
CORS_ORIGINS=[]
TRUSTED_HOSTS=["localhost","127.0.0.1"]

# Local PostgreSQL container settings. POSTGRES_PASSWORD is a secret and must be set.
POSTGRES_DB=repolume
POSTGRES_USER=repolume
POSTGRES_PASSWORD=
