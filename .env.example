# Runtime environment: development, test, or production.
APP_ENV=development

# Async SQLAlchemy PostgreSQL URL. Required. Use the postgresql+asyncpg scheme.
# Production also requires managed credentials and ssl=require, ssl=verify-ca, or
# ssl=verify-full. Supply values through an untracked file or platform secret store.
DATABASE_URL=

# Disposable PostgreSQL URL used only by the integration suite. Never point this
# at a development, staging, or production database because tests truncate it.
TEST_DATABASE_URL=

# Redis carries only opaque job IDs. PostgreSQL remains the durable job source
# of truth. Use TLS and managed credentials in production.
REDIS_URL=

# Disposable Redis database used only by integration tests. Tests flush it.
TEST_REDIS_URL=

# Structured logging. LOG_JSON should be true in production.
LOG_LEVEL=INFO
LOG_JSON=false

# Interactive API documentation is useful locally and must be false in production.
DOCS_ENABLED=true

# Database pool and readiness settings.
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=10
DATABASE_READY_TIMEOUT_SECONDS=2

# Worker delivery, recovery, heartbeat, and bounded retry settings.
WORKER_STREAM_NAME=repolume:indexing
WORKER_CONSUMER_GROUP=repolume-workers
WORKER_POLL_TIMEOUT_MS=1000
WORKER_RECONCILE_INTERVAL_SECONDS=5
WORKER_HEARTBEAT_INTERVAL_SECONDS=5
WORKER_ABANDONED_AFTER_SECONDS=30
WORKER_MAX_ATTEMPTS=3
WORKER_RETRY_BASE_SECONDS=2
WORKER_RETRY_MAX_SECONDS=60
WORKER_STREAM_MAX_LENGTH=10000

# Fixed Git executable and hard clone/discovery limits. Connected repository
# code is never executed, imported, built, installed, or tested.
CLONE_GIT_EXECUTABLE=/usr/bin/git
CLONE_TIMEOUT_SECONDS=120
CLONE_MAX_REPOSITORY_BYTES=524288000
CLONE_MAX_FILE_BYTES=2097152
CLONE_MAX_FILE_COUNT=20000
CLONE_MAX_DISCOVERED_BYTES=262144000
CLONE_PROCESS_MEMORY_BYTES=1073741824
CLONE_PROCESS_CPU_SECONDS=120

# Static Tree-sitter parsing and deterministic chunking limits. Parser input
# remains bounded by the discovered per-file limit. Chunk contents stay transient
# until the trusted worker writes complete citation payloads to scoped Qdrant.
PARSER_MAX_INPUT_BYTES=2097152
PARSER_MAX_SYMBOLS_PER_FILE=5000
PARSER_MAX_SYMBOL_BYTES=524288
PARSER_MAX_CHUNK_BYTES=32768
PARSER_MAX_CHUNKS_PER_FILE=2000
PARSER_MAX_TOTAL_CHUNKS=50000
PARSER_MAX_TOTAL_CHUNK_BYTES=67108864
PARSER_MAX_DOCUMENT_SECTION_BYTES=262144
PARSER_MAX_WARNINGS_PER_FILE=50
PARSER_MAX_CALL_SITES_PER_FILE=10000
PARSER_MAX_TOTAL_CALL_SITES=100000
PARSER_MAX_CALL_EXPRESSION_BYTES=2048
PARSER_TIMEOUT_SECONDS=180
# Resource ceilings applied to the isolated static-parser process.
PARSER_PROCESS_MEMORY_BYTES=2147483648
PARSER_PROCESS_CPU_SECONDS=120

# Private embedding service. The API is not user-facing. The worker sends only
# bounded preprocessed chunks over authenticated private HTTP. Use an independent
# random service credential of at least 32 characters.
EMBEDDING_SERVICE_URL=http://127.0.0.1:8100
EMBEDDING_SERVICE_TOKEN=
EMBEDDING_MODEL_IDENTIFIER=jinaai/jina-embeddings-v2-base-code
EMBEDDING_MODEL_REVISION=516f4baf13dec4ddddda8631e019b5737c8bc250
EMBEDDING_DIMENSION=768
EMBEDDING_PREPROCESSING_VERSION=repolume-embedding-v1
EMBEDDING_BATCH_SIZE=16
EMBEDDING_MAX_DOCUMENT_BYTES=49152
EMBEDDING_CONNECT_TIMEOUT_SECONDS=3
EMBEDDING_READ_TIMEOUT_SECONDS=60
EMBEDDING_MAX_ATTEMPTS=3
EMBEDDING_RETRY_BASE_SECONDS=0.25

# Embedding-service-only bounds and model-cache behavior. Production images
# preload the pinned public model artifacts and must run with local-files-only true.
# The cache path must be absolute. Production rejects placeholder service tokens.
EMBEDDING_ENVIRONMENT=development
EMBEDDING_LOG_LEVEL=INFO
EMBEDDING_LOG_JSON=false
EMBEDDING_MODEL_CACHE_DIR=/tmp/repolume-models
EMBEDDING_MODEL_LOCAL_FILES_ONLY=false
EMBEDDING_MODEL_THREADS=2
EMBEDDING_MODEL_DIMENSION=768
EMBEDDING_MODEL_MAX_TOKENS=8192
EMBEDDING_MAX_DOCUMENTS_PER_REQUEST=32
EMBEDDING_MAX_TEXT_BYTES_PER_DOCUMENT=49152
EMBEDDING_MAX_TOTAL_TEXT_BYTES=1048576
EMBEDDING_MAX_REQUEST_BYTES=1228800
EMBEDDING_REQUEST_TIMEOUT_SECONDS=60
EMBEDDING_MAX_CONCURRENT_REQUESTS=2

# Qdrant vector storage. Use authenticated HTTPS Qdrant Cloud in production.
# Local development may omit the API key only for a loopback/private instance.
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=repolume_chunks
QDRANT_TIMEOUT_SECONDS=5
QDRANT_UPSERT_BATCH_SIZE=128
QDRANT_MAX_ATTEMPTS=3
QDRANT_RETRY_BASE_SECONDS=0.25

# Authenticated repository-question retrieval. These are server-owned controls;
# clients cannot override ranking, thresholds, evidence budgets, or timeouts.
RAG_QUESTION_MIN_CHARACTERS=3
RAG_QUESTION_MAX_BYTES=4096
RAG_QUESTION_MAX_TOKENS=512
RAG_RETRIEVAL_TOP_K=6
RAG_RETRIEVAL_OVERFETCH=12
RAG_RETRIEVAL_SCORE_THRESHOLD=0.25
RAG_MAX_EVIDENCE_PER_FILE=3
RAG_MAX_EVIDENCE_BYTES=32768
RAG_MAX_EVIDENCE_ITEM_BYTES=12288
RAG_TOTAL_TIMEOUT_SECONDS=30

# Hosted grounded-synthesis provider. Production accepts only the exact reviewed
# OpenAI URL below or https://generativelanguage.googleapis.com/v1beta/openai.
# The API uses the stateless Responses API
# with strict structured output and store=false. The key is API-only and must
# not be supplied to the indexing worker or embedding service. The deterministic
# provider is test-only and is rejected outside APP_ENV=test.
LLM_PROVIDER=openai
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-5.4-mini-2026-03-17
LLM_PROMPT_VERSION=repolume-grounded-v1
LLM_MAX_OUTPUT_TOKENS=1200
LLM_MAX_ANSWER_CHARACTERS=8000
LLM_CONNECT_TIMEOUT_SECONDS=3
LLM_READ_TIMEOUT_SECONDS=20
LLM_MAX_ATTEMPTS=2
LLM_RETRY_BASE_SECONDS=0.25
LLM_MAX_CONCURRENT_REQUESTS=8

# Bounded direct-agent controls. Production permits exactly the three internal
# read-only tools search_code, get_history, and find_callers. The model cannot override these
# ceilings, repository scope, GitHub destinations, revisions, or vector filters.
AGENT_MAX_TOOL_CALLS=4
AGENT_TOOL_TIMEOUT_SECONDS=8
AGENT_PROVIDER_TIMEOUT_SECONDS=20
AGENT_TOTAL_TIMEOUT_SECONDS=45
AGENT_MAX_TOOL_RESULT_BYTES=32768
AGENT_MAX_TOTAL_EVIDENCE_BYTES=65536
AGENT_HISTORY_COMMIT_LIMIT=3
AGENT_HISTORY_MAX_MESSAGE_BYTES=2048
AGENT_HISTORY_MAX_PATCH_BYTES=8192
AGENT_HISTORY_MAX_PATHS=20
AGENT_CALLER_RESULT_LIMIT=20
AGENT_MAX_FINAL_OUTPUT_TOKENS=1200

# GitHub App identity and OAuth. Configure the app with read-only Contents,
# Metadata, and Pull requests permissions and subscribe to installation,
# installation_repositories, push, and repository events. IDs are identifiers;
# client secret, private key, and webhook secret are secrets.
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://127.0.0.1:8000/api/v1/auth/github/callback
# Optional server-only token for higher unauthenticated public GitHub API limits.
# This token never grants public-import authorization and is never sent to clients.
GITHUB_PUBLIC_API_TOKEN=

# Optional Google OIDC login. When enabled, all three settings are required. The
# callback is fixed to /api/v1/auth/google/callback; production requires HTTPS and
# the callback host in TRUSTED_HOSTS. Keep the client secret server-side only.
GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://127.0.0.1:8000/api/v1/auth/google/callback

# Browser client origin. In production it is required, must be an HTTPS origin
# without a path/query/credentials, and must exactly appear in CORS_ORIGINS. The
# OAuth callback sets the refresh cookie then redirects here without any token,
# code, state, or other credential in the URL.
FRONTEND_URL=http://127.0.0.1:5173

# Public frontend build-time API origin. This value is embedded in browser assets;
# it must contain no secret and normally points to the same public API origin.
VITE_API_BASE_URL=http://127.0.0.1:8000

# RepoLume token signing and keyed hashing secrets. Use independent random values
# of at least 32 characters, supplied by a secret store in production.
ACCESS_TOKEN_SECRET=
TOKEN_HASH_SECRET=

# Authentication lifetimes in seconds. Defaults are 10-minute OAuth state,
# 15-minute access token, 30-day refresh token, and 8-hour membership freshness.
OAUTH_STATE_TTL_SECONDS=600
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
INSTALLATION_MEMBERSHIP_TTL_SECONDS=28800
PUBLIC_REPOSITORY_VISIBILITY_TTL_SECONDS=900
PUBLIC_REPOSITORY_LIMIT_PER_USER=20
PUBLIC_IMPORT_ACTIVE_LIMIT_PER_USER=2
PUBLIC_GITHUB_TIMEOUT_SECONDS=5
REFRESH_COOKIE_NAME=repolume_refresh_token

# JSON arrays. Production origins must use HTTPS and hosts must be explicit.
CORS_ORIGINS=["http://127.0.0.1:5173"]
TRUSTED_HOSTS=["localhost","127.0.0.1"]

# Freshness comparison and discovered target-byte ceilings. An incomplete/unsafe
# comparison or an over-limit change falls back to a complete versioned rebuild.
FRESHNESS_MAX_CHANGED_FILES=300
FRESHNESS_MAX_CHANGED_BYTES=67108864

# Local PostgreSQL container settings. POSTGRES_PASSWORD is a secret and must be set.
POSTGRES_DB=repolume
POSTGRES_USER=repolume
POSTGRES_PASSWORD=
