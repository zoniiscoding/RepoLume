{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": ["app/**", "requirements.lock", "Dockerfile"]
  },
  "deploy": {
    "startCommand": "python -m app.worker",
    "restartPolicyType": "ALWAYS",
    "overlapSeconds": 0,
    "drainingSeconds": 900
  }
}
