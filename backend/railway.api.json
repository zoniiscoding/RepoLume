{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": ["app/**", "alembic/**", "alembic.ini", "requirements.lock", "Dockerfile"]
  },
  "deploy": {
    "preDeployCommand": "alembic -c alembic.ini upgrade head",
    "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port $PORT --no-access-log --timeout-graceful-shutdown 60",
    "healthcheckPath": "/api/v1/health/ready",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ALWAYS",
    "overlapSeconds": 30,
    "drainingSeconds": 60
  }
}
