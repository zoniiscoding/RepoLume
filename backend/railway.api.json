{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
  "/backend/app/**",
  "/backend/alembic/**",
  "/backend/alembic.ini",
  "/backend/requirements.lock",
  "/backend/Dockerfile",
  "/backend/railway.api.json"
]
  },
  "deploy": {
    "preDeployCommand": "alembic -c alembic.ini upgrade head",
    "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port 8000 --no-access-log --timeout-graceful-shutdown 60",
    "healthcheckPath": "/api/v1/health/ready",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ALWAYS",
    "overlapSeconds": 30,
    "drainingSeconds": 60
  }
}
